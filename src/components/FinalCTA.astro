---
import { site } from '../data/site';
---

<section id="book" class="scroll-mt-24 bg-[var(--color-mist)]/50 py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-5 sm:px-8">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
      <!-- Copy + direct contact -->
      <div class="reveal">
        <span class="eyebrow">Let’s talk</span>
        <h2 class="display-2 mt-3">Book your free consultation.</h2>
        <p class="measure mt-4 text-lg leading-relaxed text-[var(--color-slate)]">
          Twenty minutes, no obligation. Tell us where your books stand today and
          we’ll tell you exactly how we’d help — and what it would cost.
        </p>

        <div class="mt-8 space-y-3">
          <a href={site.phoneHref} class="card card-hover flex items-center gap-4 p-4">
            <span class="icon-badge">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-wide text-[var(--color-slate)]">Call</span>
              <span class="block font-semibold text-[var(--color-navy)]">{site.phone}</span>
            </span>
          </a>
          <a href={`mailto:${site.email}`} class="card card-hover flex items-center gap-4 p-4">
            <span class="icon-badge">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6 10-6"/></svg>
            </span>
            <span>
              <span class="block text-xs font-semibold uppercase tracking-wide text-[var(--color-slate)]">Email</span>
              <span class="block font-semibold text-[var(--color-navy)]">{site.email}</span>
            </span>
          </a>
          <div class="flex items-center gap-4 p-4 text-[var(--color-slate)]">
            <span class="icon-badge !bg-transparent !border-transparent">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--color-emerald)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <span class="text-sm">{site.city}, {site.regionName} · Serving the {site.areaServed}</span>
          </div>
        </div>
      </div>

      <!-- Calendly (lazy facade — injects the widget only when requested; §3/§5) -->
      <div class="reveal reveal-2">
        <div id="calendlyMount" class="card overflow-hidden p-0">
          <div id="calendlyFacade" class="flex flex-col items-center justify-center gap-4 bg-gradient-to-br from-[var(--color-navy)] to-[var(--color-navy-800)] px-6 py-16 text-center text-white">
            <span class="flex h-14 w-14 items-center justify-center rounded-2xl bg-[rgba(18,163,126,0.2)] text-[var(--color-emerald-bright)]">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
            </span>
            <div>
              <p class="font-[var(--font-display)] text-xl font-semibold">Pick a time that works</p>
              <p class="mt-1 text-sm text-[#9fb2ca]">Live availability — choose a slot and you’re booked.</p>
            </div>
            <button id="calendlyLoad" data-magnetic class="btn btn-gold text-base">Open the calendar</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline define:vars={{ calendlyUrl: site.calendly }}>
  (function () {
    const btn = document.getElementById('calendlyLoad');
    const mount = document.getElementById('calendlyMount');
    const facade = document.getElementById('calendlyFacade');
    if (!btn || !mount || !facade) return;

    let loaded = false;
    btn.addEventListener('click', () => {
      if (loaded) return;
      loaded = true;
      facade.innerHTML =
        '<div style="padding:2.5rem;text-align:center;color:#9fb2ca;font-size:0.9rem">Loading calendar…</div>';

      // Calendly widget stylesheet + script, injected on demand.
      const css = document.createElement('link');
      css.rel = 'stylesheet';
      css.href = 'https://assets.calendly.com/assets/external/widget.css';
      document.head.appendChild(css);

      const s = document.createElement('script');
      s.src = 'https://assets.calendly.com/assets/external/widget.js';
      s.async = true;
      s.onload = function () {
        mount.innerHTML =
          '<div class="calendly-inline-widget" data-url="' +
          calendlyUrl +
          '" style="min-width:320px;height:680px"></div>';
        if (window.Calendly && window.Calendly.initInlineWidgets) {
          window.Calendly.initInlineWidgets();
        }
      };
      document.body.appendChild(s);
    });
  })();
</script>
