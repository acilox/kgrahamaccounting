---
// Credential / trust strip — reinforces authority right below the hero.
const items = [
  'QuickBooks Certified ProAdvisor',
  'B.S. Accounting — Rutgers University',
  'M.S. Accounting & Information Systems',
  'MBA',
  '14+ Years in Accounting & Audit',
  'FAR · CAS · Uniform Guidance',
  'Multi-State Payroll Compliance',
  'Indirect Cost Rate Negotiation',
];
const loop = [...items, ...items];
---

<section aria-label="Credentials" class="border-y border-[var(--color-mist)] bg-[var(--color-mist)]/40 py-5">
  <div class="marquee">
    <div class="marquee__track">
      {
        loop.map((item) => (
          <span class="mx-6 flex shrink-0 items-center gap-2.5 text-sm font-semibold text-[var(--color-slate)]">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 2 2.4 7.4H22l-6 4.6 2.3 7.4-6.3-4.6L5.7 21.4 8 14 2 9.4h7.6z"/></svg>
            {item}
          </span>
        ))
      }
    </div>
  </div>
</section>
