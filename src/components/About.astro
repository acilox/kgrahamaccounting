---
import { site } from '../data/site';
const credentials = [
  'B.S. in Accounting — Rutgers University',
  'M.S. in Accounting & Information Systems',
  'Master of Business Administration (MBA)',
  'QuickBooks Certified ProAdvisor',
];
---

<section id="about" class="bg-[var(--color-mist)]/40 py-20 sm:py-28">
  <div class="mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[0.85fr_1.15fr]">
    <!-- Portrait placeholder -->
    <div class="reveal">
      <div class="relative mx-auto max-w-sm">
        <div class="absolute -inset-3 -z-10 rounded-[1.75rem] bg-gradient-to-br from-[var(--color-emerald-soft)] to-[var(--color-gold-soft)] blur-xl"></div>
        <!-- Replace with a real headshot at go-live: import from src/assets and use <Image>. -->
        <div class="flex aspect-[4/5] items-center justify-center overflow-hidden rounded-[1.5rem] border border-[var(--color-mist)] bg-gradient-to-br from-[var(--color-navy)] to-[var(--color-navy-800)] text-white">
          <div class="text-center">
            <span class="font-[var(--font-display)] text-6xl font-semibold text-[var(--color-emerald-bright)]">KG</span>
            <p class="mt-3 px-8 text-xs text-[#9fb2ca]">Add Kayon’s professional headshot here</p>
          </div>
        </div>
        <div class="card absolute -bottom-5 -right-2 flex items-center gap-3 p-3.5 shadow-xl sm:-right-6">
          <span class="icon-badge !h-10 !w-10 !rounded-lg !bg-[var(--color-gold-soft)] !text-[var(--color-gold)] !border-[var(--color-gold-soft)]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 6v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6z"/></svg>
          </span>
          <div>
            <p class="text-sm font-semibold text-[var(--color-navy)]">14+ years</p>
            <p class="text-xs text-[var(--color-slate)]">accounting & federal audit</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bio -->
    <div class="reveal reveal-2">
      <span class="eyebrow">Meet your accountant</span>
      <h2 class="display-2 mt-3">Kayon Graham</h2>
      <p class="mt-2 text-[var(--color-slate)]">Founder &amp; Principal · {site.credential}</p>

      <div class="measure mt-6 space-y-4 text-[17px] leading-relaxed text-[var(--color-ink)]">
        <p>
          Kayon founded K. Graham Accounting &amp; Advisory after more than fourteen
          years spent on both sides of the ledger — keeping the books <em>and</em>
          auditing them. That's a rare vantage point, and it changes everything about
          how she runs an engagement.
        </p>
        <p>
          Her specialty is the work most firms avoid: federal grant and contract
          compliance, indirect cost rates, and the kind of audit-ready reporting that
          keeps funding secure. She understands how auditors think about risk, so she
          builds your finances to answer their questions before they're asked.
        </p>
        <p>
          The result is simple: clean books, fewer surprises, and an accountant who
          treats your compliance like it's her own.
        </p>
      </div>

      <ul class="mt-7 grid gap-3 sm:grid-cols-2">
        {
          credentials.map((c) => (
            <li class="flex items-start gap-2.5 text-[15px] text-[var(--color-ink)]">
              <svg class="mt-0.5 shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-emerald)" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {c}
            </li>
          ))
        }
      </ul>

      <div class="mt-8 flex flex-wrap gap-3">
        <a href="#book" class="btn btn-primary text-sm">Work with Kayon</a>
        <a href={site.socials.linkedin} target="_blank" rel="noopener noreferrer" class="btn btn-outline text-sm">
          Connect on LinkedIn
        </a>
      </div>
    </div>
  </div>
</section>
