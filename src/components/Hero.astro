---
import { site } from '../data/site';
---

<section id="top" class="relative overflow-hidden pt-28 pb-16 sm:pt-40 sm:pb-28">
  <!-- Ambient finance backdrop: ledger grid + self-drawing growth chart -->
  <div class="hero-bg" aria-hidden="true">
    <div class="hero-grid"></div>
    <svg class="hero-chart" viewBox="0 0 1440 500" preserveAspectRatio="none">
      <defs>
        <linearGradient id="heroArea" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0" stop-color="#12a37e" stop-opacity="0.20" />
          <stop offset="1" stop-color="#12a37e" stop-opacity="0" />
        </linearGradient>
        <linearGradient id="heroLine" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0" stop-color="#0d7a5f" />
          <stop offset="0.65" stop-color="#12a37e" />
          <stop offset="1" stop-color="#d6a441" />
        </linearGradient>
      </defs>
      <g class="h-float">
        <path class="h-area" fill="url(#heroArea)"
          d="M0,432 C180,418 300,412 470,372 S770,296 950,258 S1250,200 1440,166 L1440,500 L0,500 Z" />
        <path class="h-line" stroke="url(#heroLine)"
          d="M0,432 C180,418 300,412 470,372 S770,296 950,258 S1250,200 1440,166" />
        <circle class="hero-node" cx="300" cy="412" r="5" fill="#12a37e" />
        <circle class="hero-node n2" cx="700" cy="320" r="5" fill="#12a37e" />
        <circle class="hero-node n3" cx="1050" cy="236" r="5" fill="#12a37e" />
        <circle class="hero-node n4" cx="1400" cy="176" r="5" fill="#d6a441" />
      </g>
    </svg>
    <div class="hero-wash"></div>
  </div>

  <div class="relative z-10 mx-auto grid max-w-7xl items-center gap-12 px-5 sm:px-8 lg:grid-cols-[1.05fr_0.95fr] lg:gap-14">
    <!-- Copy -->
    <div class="rise-in">
      <span class="chip mb-5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        Serving the DMV · Remote nationwide
      </span>

      <h1 class="display-1">
        Fuel your growth,<br />
        <span class="text-gradient">not your paperwork.</span>
      </h1>

      <p class="measure mt-6 text-lg leading-relaxed text-[var(--color-slate)]">
        Audit-ready bookkeeping, payroll, tax and federal-compliance accounting for
        small businesses, nonprofits and government contractors — built by an
        accountant who knows exactly how auditors evaluate risk.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#book" data-magnetic class="btn btn-primary text-base">Book a free consultation</a>
        <a href={site.phoneHref} class="btn btn-outline text-base">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {site.phone}
        </a>
      </div>

      <!-- Compact live-metric card — gives mobile's first screen a graphic (desktop shows the full card) -->
      <div class="mt-7 flex items-center gap-4 rounded-2xl border border-[var(--color-mist)] bg-white/70 p-3.5 shadow-[0_18px_40px_-28px_rgba(11,27,48,0.4)] backdrop-blur-sm lg:hidden">
        <svg viewBox="0 0 120 48" class="h-12 w-28 shrink-0" preserveAspectRatio="none" aria-hidden="true">
          <defs>
            <linearGradient id="sparkArea" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0" stop-color="#12a37e" stop-opacity="0.28" />
              <stop offset="1" stop-color="#12a37e" stop-opacity="0" />
            </linearGradient>
          </defs>
          <path class="h-area" fill="url(#sparkArea)" d="M2,40 C22,36 32,34 48,26 S78,16 92,12 S112,7 118,5 L118,48 L2,48 Z" />
          <path class="spark-line" stroke="#0d7a5f" d="M2,40 C22,36 32,34 48,26 S78,16 92,12 S112,7 118,5" />
        </svg>
        <div class="min-w-0">
          <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-slate)]">Grant spend · on track</p>
          <p class="mt-0.5 text-sm font-semibold text-[var(--color-navy)]">Books <span class="text-[var(--color-emerald)]">audit-ready</span> — reconciled &amp; documented</p>
        </div>
      </div>

      <!-- Trust stats -->
      <dl class="mt-11 grid max-w-lg grid-cols-3 gap-3 border-t border-[var(--color-mist)] pt-7 sm:gap-6">
        <div>
          <dt class="sr-only">Years of experience</dt>
          <dd class="font-[var(--font-display)] text-2xl font-semibold text-[var(--color-navy)] sm:text-3xl">
            <span data-count="14" data-suffix="+">14+</span>
          </dd>
          <p class="mt-1 text-[13px] text-[var(--color-slate)] sm:text-sm">years in accounting &amp; audit</p>
        </div>
        <div>
          <dt class="sr-only">Specialization</dt>
          <dd class="font-[var(--font-display)] text-2xl font-semibold text-[var(--color-navy)] sm:text-3xl">FAR<span class="text-[var(--color-gold)]">·</span>CAS</dd>
          <p class="mt-1 text-[13px] text-[var(--color-slate)] sm:text-sm">federal compliance fluent</p>
        </div>
        <div>
          <dt class="sr-only">Certification</dt>
          <dd class="font-[var(--font-display)] text-2xl font-semibold text-[var(--color-navy)] sm:text-3xl">QB</dd>
          <p class="mt-1 text-[13px] text-[var(--color-slate)] sm:text-sm">Certified ProAdvisor</p>
        </div>
      </dl>
    </div>

    <!-- Visual: audit-ready snapshot card -->
    <div class="rise-in delay-1 relative">
      <div class="floaty absolute -inset-4 -z-10 rounded-[2rem] bg-gradient-to-br from-[var(--color-emerald-soft)] to-[var(--color-gold-soft)] opacity-60 blur-2xl"></div>

      <!-- floating accent chips (desktop only, decorative) -->
      <span class="chip-float absolute -top-4 left-10 z-20 hidden items-center gap-1.5 rounded-full border border-[var(--color-emerald-soft)] bg-white px-3 py-1.5 text-xs font-semibold text-[var(--color-emerald)] shadow-lg sm:flex" aria-hidden="true">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        1099s filed
      </span>
      <span class="chip-float cf-2 absolute -bottom-4 right-10 z-20 hidden items-center gap-1.5 rounded-full border border-[var(--color-gold-soft)] bg-white px-3 py-1.5 text-xs font-semibold text-[var(--color-gold)] shadow-lg sm:flex" aria-hidden="true">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 6v6c0 5 3.4 8.5 8 10 4.6-1.5 8-5 8-10V6z"/></svg>
        GAAP-compliant
      </span>

      <div class="card relative overflow-hidden shadow-[0_40px_80px_-40px_rgba(11,27,48,0.4)]">
        <div class="scan-line" aria-hidden="true"></div>
        <div class="flex items-center justify-between border-b border-[var(--color-mist)] bg-[var(--color-navy)] px-5 py-3.5">
          <span class="text-sm font-semibold text-white">Monthly Close — Q3</span>
          <span class="chip !bg-[rgba(18,163,126,0.18)] !text-[#8ff0d3] !border-transparent">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            Audit-ready
          </span>
        </div>
        <div class="space-y-4 p-5">
          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-[var(--color-mist)] bg-[var(--color-emerald-tint)] p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-slate)]">Net revenue</p>
              <p class="mt-1 font-[var(--font-display)] text-2xl font-semibold text-[var(--color-navy)]"><span data-count="248300" data-prefix="$" data-group>$248,300</span></p>
              <p class="mt-1 text-xs font-semibold text-[var(--color-emerald)]">▲ <span data-count="12.4" data-decimals="1" data-suffix="%">12.4%</span> vs last month</p>
            </div>
            <div class="rounded-xl border border-[var(--color-mist)] bg-[var(--color-gold-soft)]/50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-slate)]">Indirect rate</p>
              <p class="mt-1 font-[var(--font-display)] text-2xl font-semibold text-[var(--color-navy)]"><span data-count="31.7" data-decimals="1" data-suffix="%">31.7%</span></p>
              <p class="mt-1 text-xs font-semibold text-[var(--color-gold)]">Within negotiated ceiling</p>
            </div>
          </div>
          <!-- mini bar chart -->
          <div class="rounded-xl border border-[var(--color-mist)] p-4">
            <div class="mb-3 flex items-center justify-between">
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-slate)]">Grant spend vs budget</p>
              <p class="text-xs font-semibold text-[var(--color-emerald)]">On track</p>
            </div>
            <div class="flex h-24 items-end gap-2.5">
              {[42, 58, 50, 71, 64, 83].map((h) => (
                <div class="bar-grow flex-1 rounded-t-md bg-gradient-to-t from-[var(--color-emerald)] to-[var(--color-emerald-bright)]" style={`height:${h}%`}></div>
              ))}
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-xl bg-[var(--color-mist)] p-3.5">
            <span class="icon-badge !h-9 !w-9">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
            </span>
            <p class="text-sm text-[var(--color-ink)]"><span class="font-semibold">Reconciled &amp; documented</span> — ready for any auditor to open the books.</p>
          </div>
        </div>
      </div>
      <p class="mt-3 text-center text-xs text-[var(--color-slate)]">Illustrative reporting view</p>
    </div>
  </div>
</section>
