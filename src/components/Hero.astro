---
import { site } from '../data/site';
---

<section id="top" class="relative overflow-hidden pt-32 pb-20 sm:pt-40 sm:pb-28">
  <div class="mx-auto grid max-w-7xl items-center gap-14 px-5 sm:px-8 lg:grid-cols-[1.05fr_0.95fr]">
    <!-- Copy -->
    <div class="reveal">
      <span class="chip mb-5">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
        Serving the DMV · Remote nationwide
      </span>

      <h1 class="display-1">
        Fuel your growth,<br />
        <span class="text-gradient">not your paperwork.</span>
      </h1>

      <p class="measure mt-6 text-lg leading-relaxed text-[var(--color-slate)]">
        Audit-ready bookkeeping, payroll, tax and federal-compliance accounting for
        small businesses, nonprofits and government contractors — built by an
        accountant who knows exactly how auditors evaluate risk.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <a href="#book" data-magnetic class="btn btn-primary text-base">Book a free consultation</a>
        <a href={site.phoneHref} class="btn btn-outline text-base">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {site.phone}
        </a>
      </div>

      <!-- Trust stats -->
      <dl class="mt-11 grid max-w-lg grid-cols-3 gap-6 border-t border-[var(--color-mist)] pt-7">
        <div>
          <dt class="sr-only">Years of experience</dt>
          <dd class="font-[var(--font-display)] text-3xl font-semibold text-[var(--color-navy)]">
            <span data-count="14" data-suffix="+">14+</span>
          </dd>
          <p class="mt-1 text-sm text-[var(--color-slate)]">years in accounting &amp; audit</p>
        </div>
        <div>
          <dt class="sr-only">Specialization</dt>
          <dd class="font-[var(--font-display)] text-3xl font-semibold text-[var(--color-navy)]">FAR<span class="text-[var(--color-gold)]">·</span>CAS</dd>
          <p class="mt-1 text-sm text-[var(--color-slate)]">federal compliance fluent</p>
        </div>
        <div>
          <dt class="sr-only">Certification</dt>
          <dd class="font-[var(--font-display)] text-3xl font-semibold text-[var(--color-navy)]">QB</dd>
          <p class="mt-1 text-sm text-[var(--color-slate)]">Certified ProAdvisor</p>
        </div>
      </dl>
    </div>

    <!-- Visual: audit-ready snapshot card -->
    <div class="reveal reveal-2 relative">
      <div class="absolute -inset-4 -z-10 rounded-[2rem] bg-gradient-to-br from-[var(--color-emerald-soft)] to-[var(--color-gold-soft)] opacity-60 blur-2xl"></div>
      <div class="card overflow-hidden shadow-[0_40px_80px_-40px_rgba(11,27,48,0.4)]">
        <div class="flex items-center justify-between border-b border-[var(--color-mist)] bg-[var(--color-navy)] px-5 py-3.5">
          <span class="text-sm font-semibold text-white">Monthly Close — Q3</span>
          <span class="chip !bg-[rgba(18,163,126,0.18)] !text-[#8ff0d3] !border-transparent">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
            Audit-ready
          </span>
        </div>
        <div class="space-y-4 p-5">
          <div class="grid grid-cols-2 gap-3">
            <div class="rounded-xl border border-[var(--color-mist)] bg-[var(--color-emerald-tint)] p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-slate)]">Net revenue</p>
              <p class="mt-1 font-[var(--font-display)] text-2xl font-semibold text-[var(--color-navy)]">$248,300</p>
              <p class="mt-1 text-xs font-semibold text-[var(--color-emerald)]">▲ 12.4% vs last month</p>
            </div>
            <div class="rounded-xl border border-[var(--color-mist)] bg-[var(--color-gold-soft)]/50 p-4">
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-slate)]">Indirect rate</p>
              <p class="mt-1 font-[var(--font-display)] text-2xl font-semibold text-[var(--color-navy)]">31.7%</p>
              <p class="mt-1 text-xs font-semibold text-[var(--color-gold)]">Within negotiated ceiling</p>
            </div>
          </div>
          <!-- mini bar chart -->
          <div class="rounded-xl border border-[var(--color-mist)] p-4">
            <div class="mb-3 flex items-center justify-between">
              <p class="text-xs font-semibold uppercase tracking-wide text-[var(--color-slate)]">Grant spend vs budget</p>
              <p class="text-xs font-semibold text-[var(--color-emerald)]">On track</p>
            </div>
            <div class="flex h-24 items-end gap-2.5">
              {[42, 58, 50, 71, 64, 83].map((h) => (
                <div class="flex-1 rounded-t-md bg-gradient-to-t from-[var(--color-emerald)] to-[var(--color-emerald-bright)]" style={`height:${h}%`}></div>
              ))}
            </div>
          </div>
          <div class="flex items-center gap-3 rounded-xl bg-[var(--color-mist)] p-3.5">
            <span class="icon-badge !h-9 !w-9">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
            </span>
            <p class="text-sm text-[var(--color-ink)]"><span class="font-semibold">Reconciled &amp; documented</span> — ready for any auditor to open the books.</p>
          </div>
        </div>
      </div>
      <p class="mt-3 text-center text-xs text-[var(--color-slate)]">Illustrative reporting view</p>
    </div>
  </div>
</section>
