---
import { site } from '../data/site';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const links = [
  { href: '#services', label: 'Services' },
  { href: '#federal', label: 'Federal Compliance' },
  { href: '#about', label: 'About' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#faq', label: 'FAQ' },
];
---

<header id="siteNav" class="fixed inset-x-0 top-0 z-50">
  <nav class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-5 py-3.5 sm:px-8">
    <!-- Brand -->
    <a href="#top" class="flex items-center gap-2.5" aria-label={site.name}>
      <img src={`${base}/favicon.svg`} width="38" height="38" alt="" class="rounded-lg" />
      <span class="hidden leading-tight sm:block">
        <span class="block font-[var(--font-display)] text-[1.02rem] font-semibold text-[var(--color-navy)]"
          >K. Graham</span
        >
        <span class="block text-[0.66rem] font-semibold uppercase tracking-[0.16em] text-[var(--color-slate)]"
          >Accounting &amp; Advisory</span
        >
      </span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-7 lg:flex">
      {
        links.map((l) => (
          <li>
            <a
              href={l.href}
              data-spy={l.href.slice(1)}
              class="nav-link text-sm font-medium text-[var(--color-slate)] transition-colors hover:text-[var(--color-emerald)]"
            >
              {l.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Contact + CTA (contact in header, playbook §7) -->
    <div class="flex items-center gap-3">
      <a
        href={site.phoneHref}
        class="hidden items-center gap-1.5 text-sm font-semibold text-[var(--color-navy)] transition-colors hover:text-[var(--color-emerald)] md:flex"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {site.phone}
      </a>
      <a href="#book" data-magnetic class="btn btn-primary !px-4 !py-2.5 text-sm">Book a consult</a>

      <button
        id="navToggle"
        class="lg:hidden"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--color-navy)" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobileMenu" class="hidden border-t border-[var(--color-mist)] bg-[var(--color-paper)]/95 backdrop-blur lg:hidden">
    <ul class="mx-auto flex max-w-7xl flex-col gap-1 px-5 py-4">
      {
        links.map((l) => (
          <li>
            <a href={l.href} class="block rounded-lg px-3 py-2.5 font-medium text-[var(--color-navy)] hover:bg-[var(--color-mist)]">
              {l.label}
            </a>
          </li>
        ))
      }
      <li class="mt-1 flex gap-2 px-1">
        <a href={site.phoneHref} class="btn btn-outline flex-1 !py-2.5 text-sm">Call {site.phone}</a>
        <a href="#book" class="btn btn-primary flex-1 !py-2.5 text-sm">Book</a>
      </li>
    </ul>
  </div>
</header>
